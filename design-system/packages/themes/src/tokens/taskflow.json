{
  "meta": {
    "name": "taskflow",
    "version": "0.0.1",
    "extends": "global"
  },
  "foundation": {
    "radius": {
      "none": 0,
      "sm": 6,
      "md": 10,
      "lg": 14,
      "xl": 20,
      "full": 9999
    },
    "typography": {
      "fontFamily": {
        "base": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif",
        "heading": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif",
        "mono": "'JetBrains Mono', 'Fira Code', 'Consolas', monospace"
      }
    }
  },
  "semantic": {
    "elevation": {
      "sm": "0 1px 2px 0 rgba(15, 23, 42, 0.06)",
      "md": "0 4px 8px -2px rgba(15, 23, 42, 0.08), 0 2px 4px -2px rgba(15, 23, 42, 0.04)",
      "lg": "0 12px 20px -4px rgba(15, 23, 42, 0.10), 0 4px 8px -2px rgba(15, 23, 42, 0.06)",
      "xl": "0 24px 32px -8px rgba(15, 23, 42, 0.12), 0 8px 16px -4px rgba(15, 23, 42, 0.06)"
    },
    "palette": {
      "primary": {
        "main": "#6366F1",
        "light": "#818CF8",
        "dark": "#4338CA",
        "contrastText": "#ffffff"
      },
      "secondary": {
        "main": "#0EA5E9",
        "light": "#38BDF8",
        "dark": "#0369A1",
        "contrastText": "#ffffff"
      },
      "success": {
        "main": "#10B981",
        "light": "#34D399",
        "dark": "#047857",
        "contrastText": "#ffffff"
      },
      "warning": {
        "main": "#F59E0B",
        "light": "#FBBF24",
        "dark": "#B45309",
        "contrastText": "#ffffff"
      },
      "error": {
        "main": "#EF4444",
        "light": "#F87171",
        "dark": "#B91C1C",
        "contrastText": "#ffffff"
      },
      "info": {
        "main": "#0EA5E9",
        "light": "#38BDF8",
        "dark": "#0369A1",
        "contrastText": "#ffffff"
      },
      "text": {
        "primary": "#0F172A",
        "secondary": "#475569",
        "disabled": "#94A3B8"
      },
      "background": {
        "default": "#F8FAFC",
        "paper": "#FFFFFF"
      },
      "divider": "#E2E8F0",
      "action": {
        "active": "#475569",
        "hover": "rgba(15, 23, 42, 0.04)",
        "hoverOpacity": 0.04,
        "selected": "rgba(99, 102, 241, 0.08)",
        "selectedOpacity": 0.08,
        "disabled": "rgba(15, 23, 42, 0.26)",
        "disabledBackground": "rgba(15, 23, 42, 0.08)",
        "disabledOpacity": 0.38,
        "focus": "rgba(99, 102, 241, 0.16)",
        "focusOpacity": 0.16,
        "activatedOpacity": 0.12
      }
    }
  },
  "components": {
    "button": {
      "sizes": {
        "small": {
          "px": 12,
          "py": 4,
          "fontSize": 13,
          "minHeight": 32,
          "radius": 8
        },
        "medium": {
          "px": 16,
          "py": 8,
          "fontSize": 14,
          "minHeight": 38,
          "radius": 10
        },
        "large": {
          "px": 20,
          "py": 10,
          "fontSize": 15,
          "minHeight": 44,
          "radius": 10
        }
      },
      "variants": {
        "solid": {},
        "outline": { "borderWidth": 1 },
        "ghost": {}
      }
    },
    "field": {
      "sizes": {
        "small": {
          "px": 10,
          "py": 6,
          "fontSize": 13,
          "minHeight": 36,
          "radius": 8
        },
        "medium": {
          "px": 12,
          "py": 8,
          "fontSize": 14,
          "minHeight": 40,
          "radius": 10
        }
      },
      "helperTextSpacing": 4
    },
    "dialog": {
      "radius": 14,
      "padding": 24,
      "titleTypography": {
        "fontSize": 20,
        "fontWeight": 600,
        "lineHeight": 1.5
      }
    },
    "table": {
      "rowHeight": 56,
      "headerHeight": 48
    }
  }
}
