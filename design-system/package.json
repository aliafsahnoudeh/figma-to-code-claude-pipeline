{
  "name": "@taskflow/root",
  "version": "0.0.1",
  "private": true,
  "description": "TaskFlow design system — token-driven MUI wrappers used by the demo app.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "build": "pnpm -r --filter='./packages/**' build && pnpm -r --filter='./apps/**' build",
    "build:packages": "pnpm -r --filter='./packages/**' build",
    "build:apps": "pnpm -r --filter='./apps/**' build",
    "dev": "pnpm --parallel --filter='./packages/**' --filter=@taskflow/storybook dev",
    "dev:storybook": "pnpm --filter @taskflow/storybook dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "storybook": "pnpm --filter @taskflow/storybook storybook",
    "build:storybook": "pnpm --filter @taskflow/storybook build-storybook",
    "validate:tokens": "tsx scripts/validate-tokens.ts",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    }
  },
  "keywords": [
    "design-system",
    "react",
    "mui",
    "tokens",
    "theming"
  ],
  "license": "MIT"
}
