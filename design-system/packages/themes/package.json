{
  "name": "@taskflow/themes",
  "version": "0.0.1",
  "description": "Token-driven theming for the TaskFlow demo design system.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/tokens"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mui/material": "^7.3.7",
    "@mui/material-nextjs": "^7.3.7",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@emotion/cache": "^11.13.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
